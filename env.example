# ============================================================
# .env.example - Copy to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# App
DEBUG=false
SECRET_KEY=your-very-long-random-secret-key-here

# Database
DATABASE_URL=postgresql+asyncpg://hiring_user:hiring_pass@localhost:5432/hiring_db

# AWS S3
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
S3_BUCKET_CVS=your-hiring-cvs-bucket
S3_BUCKET_VIDEOS=your-hiring-videos-bucket

# OpenAI (for LLM + Whisper)
OPENAI_API_KEY=sk-...

# Anthropic (optional alternative LLM)
ANTHROPIC_API_KEY=sk-ant-...

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hr@your-company.com
SMTP_PASSWORD=your-app-password
EMAIL_MONITOR_ADDRESS=cv-submissions@your-company.com

# Twilio (calls)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Vector DB (ChromaDB)
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Redis (for Celery background workers)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Matching threshold (default 85%)
CV_MATCH_THRESHOLD=85.0

# CORS origins
ALLOWED_ORIGINS=["http://localhost:3000","https://your-frontend-domain.com"]
